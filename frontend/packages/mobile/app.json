{
  "expo": {
    "name": "SearchPet",
    "slug": "search-pet",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "searchpet",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#C24E1A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.searchpet.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Necesitamos tu ubicación para mostrar mascotas perdidas cerca de ti.",
        "NSCameraUsageDescription": "Necesitamos acceso a tu cámara para tomar fotos de mascotas.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tu galería para seleccionar fotos de mascotas.",
        "NSUserNotificationsUsageDescription": "Queremos avisarte cuando alguien vea a tu mascota perdida."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#C24E1A"
      },
      "package": "com.searchpet.app",
      "versionCode": 3,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-image-picker",
      "expo-camera",
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "b5b10d02-5e2b-4245-b34b-bf63f189358e"
      }
    }
  }
}
