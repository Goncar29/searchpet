# ============================================================
# SearchPet — Backend Environment Variables
# ============================================================

# REQUIRED — server will not start without these
PORT=8080
ENVIRONMENT=development
JWT_SECRET=change-me-in-production-minimum-32-chars
DATABASE_URL=postgres://searchpet:searchpet@localhost:5432/searchpet?sslmode=disable

# OPTIONAL — enables: photo uploads (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OPTIONAL — enables: push notifications (Firebase FCM)
FIREBASE_CREDENTIALS_JSON=

# OPTIONAL — enables: email notifications (SendGrid)
SENDGRID_API_KEY=

# OPTIONAL — enables: SMS notifications (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OPTIONAL — enables: configurable CORS origins (default: localhost)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# OPTIONAL — enables: shareable pet links
APP_URL=http://localhost:8080

# OPTIONAL — enables: email verification flow
ENABLE_EMAIL_VERIFICATION=false
