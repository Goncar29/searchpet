# ============================================================
# SearchPet ó Backend Environment Variables
# Copi· este archivo como .env y complet· los valores
# ============================================================

# Base de datos PostgreSQL + PostGIS
DATABASE_URL=postgres://postgres:postgres@localhost:5432/searchpet?sslmode=disable

# JWT ó clave secreta para firmar tokens (72h de expiraciÛn)
JWT_SECRET=changeme_use_a_long_random_string

# Puerto del servidor HTTP (default: 8080)
PORT=8080

# Cloudinary ó credenciales para upload de im·genes (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Firebase ó ruta al archivo de credenciales para push notifications
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
