# ============================================================
# SearchPet — Backend Environment Variables
# Copiá este archivo como .env y completá los valores
# ============================================================

# REQUIRED — server will not start without these
PORT=8080
ENVIRONMENT=development
JWT_SECRET=change-me-in-production-minimum-32-chars
DATABASE_URL=postgres://searchpet:searchpet@localhost:5432/searchpet?sslmode=disable

# OPTIONAL — enables: photo uploads (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OPTIONAL — enables: push notifications (Firebase FCM)
# Paste the FULL service account JSON as a single-line string (not a file path, not base64)
# Get it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_KEY={"type":"service_account","project_id":"...","private_key_id":"..."}

# OPTIONAL — enables: configurable CORS origins (default: localhost)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# OPTIONAL — enables: shareable pet links
APP_URL=http://localhost:8080

# ── Verificación de usuarios ─────────────────────────────────────────────────

# Habilitar endpoints de verificación de email y SMS (true/false)
# Desde v1.6 el valor por defecto es true; el sistema usa noop senders si no
# hay credenciales configuradas, por lo que este flag es seguro de dejar en true.
ENABLE_EMAIL_VERIFICATION=true

# SendGrid — Email OTP
# Obtener en: https://app.sendgrid.com/settings/api_keys
# Requiere verificar el sender (noreply@searchpet.app) en SendGrid antes de enviar emails.
SENDGRID_API_KEY=

# Twilio — SMS OTP
# Obtener en: https://console.twilio.com
# NOTA: Las cuentas trial solo pueden enviar SMS a números pre-verificados en la consola Twilio.
# Verificá los números destinatarios en: https://console.twilio.com/us1/develop/phone-numbers/manage/verified
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# OPTIONAL — enables: distributed rate limiting (Redis)
# When unset, rate limiting uses in-memory store (single-instance only)
# REDIS_URL=redis://localhost:6379
