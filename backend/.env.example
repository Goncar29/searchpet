# ============================================
# Lost Pets API - Variables de entorno
# ============================================
# Copiar este archivo como .env y configurar

# Server
PORT=8080
ENVIRONMENT=development

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lostpets?sslmode=disable

# JWT Secret (cambiar en producción)
JWT_SECRET=super-secret-key-change-in-production-please

# Cloudinary (imágenes)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Firebase (notificaciones push)
FIREBASE_KEY=your-firebase-key

# App URL (para links compartibles)
APP_URL=http://localhost:8080
